# Runtime
NODE_ENV=production
PORT=3001

# API behavior
CORS_ORIGIN=https://your-frontend.example.com
RATE_LIMIT_MAX=30
CAPTURE_CONCURRENCY=3
RIVE_DEBUG_DIR=

# Auth
# Option A: simple login via env credentials (recommended for single-user deployment)
AUTH_MODE=development
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Option B: gateway-injected auth headers (for proxy/multi-tenant setup)
# AUTH_MODE=production
# AUTH_HEADERS_USE_AUTH_PREFIX=true
# AUTH_USER_ID_HEADER=x-auth-user-id
# AUTH_TENANT_ID_HEADER=x-auth-tenant-id
# AUTH_CLIENT_ID_HEADER=x-auth-client-id
